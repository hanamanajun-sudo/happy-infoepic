---
export interface Props {
  who: 'happy' | 'log';
  children: string;
}

const { who, children } = Astro.props;
const label = who === 'happy' ? '🎀 해피' : '📋 로그';
const emoji = who === 'happy' ? '🎀' : '📋';
---

<div class="chat-intro" data-character={who}>
  <span class="chat-label">{label}</span>
  <p class="chat-text"><slot /></p>
</div>

<style>
.chat-intro {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 1rem 1.15rem;
  margin: 1.25rem 0;
  background: var(--color-bg-card);
  border: 2px solid var(--color-text);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sticker);
  max-width: var(--content-max);
}

.chat-intro[data-character="happy"] {
  border-left: 4px solid var(--color-primary);
  transform: rotate(-0.3deg);
}

.chat-intro[data-character="log"] {
  border-left: 4px solid var(--color-mint);
  transform: rotate(0.3deg);
  margin-left: 1.5rem;
}

.chat-label {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--color-primary-dark);
}

.chat-intro[data-character="log"] .chat-label {
  color: var(--color-mint);
}

.chat-text {
  font-size: 1rem;
  line-height: 1.65;
  color: var(--color-text);
  margin: 0;
}

.chat-text :global(a) {
  color: var(--color-primary-dark);
  text-underline-offset: 2px;
}
</style>
