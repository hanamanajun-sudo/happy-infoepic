---
import Icons from './Icons.astro';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <Icons name="heart" size={18} />
      <span>해피로그</span>
    </div>
    <p class="footer-desc">오늘의 해피를 기록하다 — 라이프스타일 &amp; 트렌드 큐레이션</p>
    <nav class="footer-links">
      <a href="/privacy">개인정보처리방침</a>
    </nav>
    <p class="footer-copy">&copy; {year} happy.infoepic.com · 무단 전재 및 재배포 금지</p>
  </div>
</footer>

<style>
.site-footer {
  background: var(--color-text);
  color: rgba(255,248,238,0.7);
  margin-top: 5rem;
  padding-block: 2.25rem;
  position: relative;
}

.site-footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: repeating-linear-gradient(
    90deg,
    var(--color-primary), var(--color-primary) 12px,
    var(--color-secondary) 12px, var(--color-secondary) 24px,
    var(--color-accent) 24px, var(--color-accent) 36px
  );
}

.footer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  text-align: center;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: #fff;
  font-family: var(--font-display);
  font-weight: 400;
  font-size: 1.15rem;
}

.footer-brand :global(.icon) {
  color: var(--color-primary);
}

.footer-desc {
  font-family: var(--font-hand);
  font-size: 0.95rem;
  color: rgba(255,248,238,0.6);
}

.footer-links {
  display: flex;
  gap: 1rem;
  font-size: 0.82rem;
  margin-top: 0.5rem;
}

.footer-links a {
  color: rgba(255,248,238,0.55);
  transition: color 0.15s;
}

.footer-links a:hover {
  color: var(--color-secondary);
}

.footer-copy {
  font-size: 0.78rem;
  color: rgba(255,248,238,0.4);
  margin-top: 0.25rem;
}
</style>
