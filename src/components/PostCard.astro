---
import Icons from './Icons.astro';
import { topCategory, categoryDef, categoryHref } from '../lib/categories';

export interface Props {
  title: string;
  slug: string;
  date: string;
  category?: string;
  description?: string;
  thumbnail?: string;
  numericId: number;
  rotate?: number;
}

const { title, slug, date, category, description, thumbnail, rotate = 0 } = Astro.props;
const formattedDate = date ? new Date(date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const cat = categoryDef(topCategory(category));
---
<article class="post-card" style={`--tilt: ${rotate}deg`}>
  <a href={`/entry/${slug}/`} class="card-link" tabindex="-1" aria-hidden="true">
    <div class="card-thumbnail">
      {thumbnail
        ? <img src={thumbnail} alt={title} loading="lazy" width="400" height="225" />
        : <div class="thumbnail-placeholder" style={`--cat-color: var(--${cat.color})`}><Icons name="sparkle" size={32} /></div>
      }
    </div>
  </a>

  <div class="card-body">
    {topCategory(category) && (
      <a href={`${categoryHref(category)}/`} class="category-badge" style={`--cat-color: var(--${cat.color})`}>
        {cat.label}
      </a>
    )}

    <h2 class="card-title">
      <a href={`/entry/${slug}/`}>{title}</a>
    </h2>

    {description && <p class="card-desc">{description}</p>}

    <div class="card-meta">
      <span class="meta-date">
        <Icons name="calendar" size={13} />
        {formattedDate}
      </span>
      <a href={`/entry/${slug}/`} class="read-more">
        더 보기 <Icons name="arrow-right" size={13} />
      </a>
    </div>
  </div>
</article>

<style>
.post-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sticker), var(--shadow-sm);
  border: 2px solid var(--color-text);
  transition: transform 0.25s cubic-bezier(.34,1.56,.64,1), box-shadow 0.25s;
  display: flex;
  flex-direction: column;
}

.post-card:hover {
  transform: translateY(-4px) rotate(var(--tilt, -1deg));
  box-shadow: 0 5px 0 rgba(43,33,24,0.14), var(--shadow-md);
}

.card-link {
  display: block;
}

.card-thumbnail {
  aspect-ratio: 16/9;
  overflow: hidden;
  background: var(--color-bg);
  border-bottom: 2px solid var(--color-text);
}

.card-thumbnail img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s;
}

.post-card:hover .card-thumbnail img {
  transform: scale(1.05) rotate(0.5deg);
}

.thumbnail-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--cat-color, var(--color-accent));
  color: rgba(255,255,255,0.85);
}

.card-body {
  padding: 1rem 1.1rem 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.category-badge {
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.28rem 0.7rem;
  border-radius: 999px;
  color: #fff;
  background: var(--cat-color, var(--color-accent));
}

.card-title {
  font-size: 1.02rem;
  font-weight: 700;
  line-height: 1.4;
}

.card-title a {
  color: var(--color-text);
  transition: color 0.15s;
}

.card-title a:hover {
  color: var(--color-primary);
}

.card-desc {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 0.5rem;
}

.meta-date {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.78rem;
  color: var(--color-text-muted);
}

.read-more {
  display: flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--color-primary-dark);
  transition: gap 0.15s;
}

.read-more:hover {
  gap: 0.4rem;
}
</style>
