---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Icons from '../components/Icons.astro';
import { CATEGORIES, topCategory } from '../lib/categories';

const allPosts = await getCollection('posts');

// Sort by date descending, filter out internal test posts (no real content)
const posts = allPosts
  .filter(p => p.data.description && p.data.description.length > 5)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const PER_PAGE = 20;
const totalPages = Math.ceil(posts.length / PER_PAGE);
const pagePosts = posts.slice(0, PER_PAGE);

const usedTopCategories = new Set(allPosts.map(p => topCategory(p.data.category)).filter(Boolean));
const activeCategories = CATEGORIES.filter(c => usedTopCategories.has(c.label));

const tilts = [-2, 1, -1, 2, -1.5, 1.5];
---
<BaseLayout
  title="해피로그"
  description="오늘의 해피를 기록하다 — 라이프스타일, 문화연예, 꿀팁, 맛집까지 큐레이션하는 20-40대 여성 정보 블로그"
  canonical="/"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-label">
          <Icons name="sparkle" size={16} />
          Daily Curation Diary
        </p>
        <h1 class="hero-title">오늘의 <mark class="highlight">해피</mark>를<br />기록하는 중</h1>
        <p class="hero-desc">라이프스타일, 문화연예, 꿀팁, 맛집까지 — 마음에 드는 정보만 골라 담는 다이어리</p>
      </div>
      <div class="hero-stats">
        <div class="stat stat-a">
          <span class="stat-num">{posts.length}</span>
          <span class="stat-label">기록된 글</span>
        </div>
        <div class="stat stat-b">
          <span class="stat-num">{activeCategories.length}</span>
          <span class="stat-label">카테고리</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories strip -->
  {activeCategories.length > 0 && (
    <section class="categories-strip">
      <div class="container">
        <div class="cats-scroll">
          {activeCategories.map(cat => (
            <a href={`/category/${cat.slug}/`} class="cat-chip" style={`--cat-color: var(--${cat.color})`}>
              {cat.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Posts grid -->
  <section class="posts-section">
    <div class="container">
      <h2 class="section-title">
        <Icons name="journal" size={20} />
        최신 기록
      </h2>
      <div class="posts-grid">
        {pagePosts.map((post, i) => (
          <div class="grid-item" style={`--delay: ${Math.min(i, 11) * 45}ms`}>
            <PostCard
              title={post.data.title}
              slug={post.data.slug}
              date={post.data.date}
              category={post.data.category}
              description={post.data.description}
              thumbnail={post.data.thumbnail}
              numericId={post.data.numericId}
              rotate={tilts[i % tilts.length]}
            />
          </div>
        ))}
      </div>

      <!-- Pagination -->
      {totalPages > 1 && (
        <nav class="pagination" aria-label="페이지네이션">
          <span />
          <div class="page-numbers">
            <span class="page-num active">1</span>
            {Array.from({ length: Math.min(totalPages - 1, 5) }, (_, i) => (
              <a href={`/page/${i + 2}/`} class="page-num">{i + 2}</a>
            ))}
            {totalPages > 7 && <span class="page-dots">…</span>}
            {totalPages > 6 && (
              <a href={`/page/${totalPages}/`} class="page-num">{totalPages}</a>
            )}
          </div>
          <a href="/page/2/" class="page-btn page-next">
            다음
            <Icons name="chevron-right" size={16} />
          </a>
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
/* Hero */
.hero {
  position: relative;
  background: var(--color-paper);
  color: var(--color-text);
  padding-block: 3.5rem 3rem;
  overflow: hidden;
  border-bottom: 3px dashed var(--color-border);
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255,79,129,0.1) 2px, transparent 2px);
  background-size: 22px 22px;
  pointer-events: none;
}

.hero-inner {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

@media (min-width: 768px) {
  .hero-inner {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.hero-label {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-hand);
  font-size: 1rem;
  color: var(--color-primary-dark);
  font-weight: 700;
  letter-spacing: 0.02em;
  margin-bottom: 0.5rem;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5.5vw, 3.1rem);
  font-weight: 400;
  line-height: 1.3;
  color: var(--color-text);
  margin-bottom: 0.85rem;
}

.hero-title .highlight {
  color: var(--color-primary-dark);
  background-color: transparent;
  background-image: linear-gradient(120deg, var(--color-primary) 0%, var(--color-primary) 100%);
  background-repeat: no-repeat;
  background-size: 100% 0.16em;
  background-position: 0 96%;
  padding-bottom: 0.05em;
  box-decoration-break: clone;
  -webkit-box-decoration-break: clone;
}

.hero-desc {
  color: var(--color-text-muted);
  font-size: 1.02rem;
  max-width: 32rem;
}

.hero-stats {
  display: flex;
  gap: 1.25rem;
  flex-shrink: 0;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 6.5rem;
  height: 6.5rem;
  border-radius: 50%;
  background: #fff;
  border: 2px dashed var(--color-primary);
  box-shadow: var(--shadow-sm);
}

.stat-a { transform: rotate(-6deg); }
.stat-b { transform: rotate(5deg); }

.stat-num {
  font-family: var(--font-display);
  font-size: 1.9rem;
  font-weight: 400;
  color: var(--color-primary-dark);
  line-height: 1;
}

.stat-label {
  font-size: 0.72rem;
  color: var(--color-text-muted);
  margin-top: 0.3rem;
}

/* Categories strip */
.categories-strip {
  border-bottom: 3px solid var(--color-text);
  padding-block: 0.85rem;
  background: var(--color-paper);
}

.cats-scroll {
  display: flex;
  gap: 0.6rem;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding-block: 0.25rem;
}

.cats-scroll::-webkit-scrollbar { display: none; }

.cat-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.4rem 0.95rem;
  background: #fff;
  border: 2px solid var(--color-text);
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--color-text);
  white-space: nowrap;
  transition: transform 0.15s, background 0.15s, color 0.15s;
}

.cat-chip:hover {
  background: var(--cat-color, var(--color-primary));
  color: #fff;
  transform: translateY(-2px) rotate(-2deg);
}

/* Posts section */
.posts-section {
  padding-block: 2.75rem;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 400;
  color: var(--color-text);
  margin-bottom: 1.5rem;
}

.section-title :global(.icon) {
  color: var(--color-primary);
}

.posts-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 600px) {
  .posts-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .posts-grid { grid-template-columns: repeat(3, 1fr); }
}

.grid-item {
  animation: reveal 0.5s cubic-bezier(.2,.8,.2,1) both;
  animation-delay: var(--delay, 0ms);
}

@media (prefers-reduced-motion: reduce) {
  .grid-item { animation: none; }
}

@keyframes reveal {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Pagination ── */
.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 3rem;
  gap: 0.5rem;
}

.page-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-text);
  background: var(--color-bg-card);
  border: 2px solid var(--color-text);
  border-radius: 999px;
  transition: transform 0.15s, background 0.15s, color 0.15s;
}

.page-btn:hover {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  transform: translateY(-2px);
}

.page-numbers {
  display: flex;
  align-items: center;
  gap: 0.2rem;
}

.page-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  font-size: 0.85rem;
  font-weight: 700;
  border-radius: 50%;
  color: var(--color-text-muted);
  transition: background 0.15s, color 0.15s;
  text-decoration: none;
}

.page-num:hover {
  background: var(--color-secondary);
  color: var(--color-text);
}

.page-num.active {
  background: var(--color-primary);
  color: #fff;
}

.page-dots {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  padding-inline: 0.15rem;
}
</style>
