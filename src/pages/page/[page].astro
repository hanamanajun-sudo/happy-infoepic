---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Icons from '../../components/Icons.astro';
import { CATEGORIES, topCategory } from '../../lib/categories';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const posts = allPosts
    .filter(p => p.data.description && p.data.description.length > 5)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  const PER_PAGE = 20;
  const totalPages = Math.ceil(posts.length / PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: {
      page: i + 2,
      totalPages,
      posts: posts.slice((i + 1) * PER_PAGE, (i + 2) * PER_PAGE),
    },
  }));
}

const { page, totalPages, posts } = Astro.props;
const tilts = [-2, 1, -1, 2, -1.5, 1.5];
const prevPage = page > 1 ? (page - 1 === 1 ? '/' : `/page/${page - 1}/`) : null;
const nextPage = page < totalPages ? `/page/${page + 1}/` : null;

// Precompute pagination numbers
const pageArr = [];
const start = Math.max(1, page - 2);
const end = Math.min(totalPages, page + 2);
if (start > 2) { pageArr.push(1, 'ellipsis'); }
else if (start === 2) { pageArr.push(1); }
for (let p = start; p <= end; p++) pageArr.push(p);
if (end < totalPages - 1) { pageArr.push('ellipsis', totalPages); }
else if (end === totalPages - 1) { pageArr.push(totalPages); }
---

<BaseLayout
  title={`해피로그 - ${page}페이지`}
  description={`오늘의 해피를 기록하다 — 해피로그 ${page}/${totalPages} 페이지`}
  canonical={`/page/${page}/`}
>
  <section class="posts-section">
    <div class="container">
      <h2 class="section-title">
        <Icons name="journal" size={20} />
        최신 기록
        <span class="page-indicator">{page} / {totalPages}</span>
      </h2>

      <div class="posts-grid">
        {posts.map((post, i) => (
          <div class="grid-item" style={`--delay: ${Math.min(i, 11) * 45}ms`}>
            <PostCard
              title={post.data.title}
              slug={post.data.slug}
              date={post.data.date}
              category={post.data.category}
              description={post.data.description}
              thumbnail={post.data.thumbnail}
              numericId={post.data.numericId}
              rotate={tilts[i % tilts.length]}
            />
          </div>
        ))}
      </div>

      <nav class="pagination" aria-label="페이지네이션">
        {prevPage ? (
          <a href={prevPage} class="page-btn page-prev">
            <Icons name="chevron-right" size={16} style="transform: rotate(180deg)" />
            이전
          </a>
        ) : <span />}
        <div class="page-numbers">
          {pageArr.map((p, idx) =>
            p === 'ellipsis' ? (
              <span class="page-dots">…</span>
            ) : (
              <a
                href={p === 1 ? '/' : `/page/${p}/`}
                class:list={['page-num', { active: p === page }]}
              >{p}</a>
            )
          )}
        </div>
        {nextPage ? (
          <a href={nextPage} class="page-btn page-next">
            다음
            <Icons name="chevron-right" size={16} />
          </a>
        ) : <span />}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
.posts-section {
  padding-block: 2.75rem 4rem;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 400;
  color: var(--color-text);
  margin-bottom: 1.5rem;
}

.section-title :global(.icon) {
  color: var(--color-primary);
}

.page-indicator {
  font-family: var(--font-sans);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-text-muted);
  margin-left: auto;
}

.posts-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 600px) {
  .posts-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .posts-grid { grid-template-columns: repeat(3, 1fr); }
}

.grid-item {
  animation: reveal 0.5s cubic-bezier(.2,.8,.2,1) both;
  animation-delay: var(--delay, 0ms);
}
@media (prefers-reduced-motion: reduce) {
  .grid-item { animation: none; }
}
@keyframes reveal {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Pagination ── */
.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 3rem;
  gap: 0.5rem;
}

.page-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-text);
  background: var(--color-bg-card);
  border: 2px solid var(--color-text);
  border-radius: 999px;
  transition: transform 0.15s, background 0.15s, color 0.15s;
}

.page-btn:hover {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  transform: translateY(-2px);
}

.page-numbers {
  display: flex;
  align-items: center;
  gap: 0.2rem;
}

.page-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  font-size: 0.85rem;
  font-weight: 700;
  border-radius: 50%;
  color: var(--color-text-muted);
  transition: background 0.15s, color 0.15s;
}

.page-num:hover {
  background: var(--color-secondary);
  color: var(--color-text);
}

.page-num.active {
  background: var(--color-primary);
  color: #fff;
}

.page-dots {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  padding-inline: 0.15rem;
}
</style>
